{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "env": {
    "LARAVEL_STORAGE_PATH": "/tmp/storage",
    "LARAVEL_BOOTSTRAP_CACHE_PATH": "/tmp/bootstrap/cache"
  },
  "build": {
    "env": {
      "LARAVEL_STORAGE_PATH": "/tmp/storage",
      "LARAVEL_BOOTSTRAP_CACHE_PATH": "/tmp/bootstrap/cache"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(assets|css|js|images)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}