{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1",
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "env": {
    "APP_BOOTSTRAP_CACHE_PATH": "/tmp/storage/bootstrap/cache",
    "APP_STORAGE_PATH": "/tmp/storage"
  },
  "build": {
    "commands": [
      "mkdir -p /tmp/storage/bootstrap/cache /tmp/storage/framework/views /tmp/storage/framework/sessions /tmp/storage/logs",
      "chmod -R 777 /tmp/storage || true"
    ],
    "env": {
      "APP_BOOTSTRAP_CACHE_PATH": "/tmp/storage/bootstrap/cache",
      "APP_STORAGE_PATH": "/tmp/storage"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(assets|css|js|images)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}